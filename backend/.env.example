# Copy this to .env for local dev, or set these as Railway service variables.
SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
# DATABASE_URL is auto-provided by Railway's Postgres add-on — no need to set manually there.
